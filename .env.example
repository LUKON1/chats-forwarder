# VK Community Token (from community admin panel → Manage → API → Create key)
VK_COMMUNITY_TOKEN=your_vk_community_token_here

# Telegram Bot Token from @BotFather
TG_BOT_TOKEN=your_telegram_bot_token_here

# Secret authorization key for secure Next.js -> Bot API communication
API_SECRET=your_super_secret_auth_token_here

# Optional: HTTP API port for the admin dashboard (defaults to 4000)
API_PORT=4000

# Required: PostgreSQL connection parameters (used in Docker Compose initialization)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=chat_forwarder

# Required: PostgreSQL connection string (must match parameters above)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?schema=public

# Required: Redis connection URL
REDIS_URL=redis://localhost:6379

# Required: JWT authorization secrets (must be set in production/local)
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Optional: Proxy gateway (SOCKS5/HTTP/HTTPS) for bypassing Telegram/VK blocks
# PROXY_URL=socks5://100.102.226.16:1080

# Optional: Public domain for receiving webhooks (used to auto-configure TG webhook URL)
# BASE_DOMAIN=msg.lukon.space

