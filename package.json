{
  "name": "chat-forwarder-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:bot": "bun --filter bot-engine dev",
    "start:bot": "bun --filter bot-engine start",
    "dev:ui": "bun --filter chat-forwarder-admin-ui dev",
    "start:ui": "bun --filter chat-forwarder-admin-ui start",
    "dev": "bun run dev:bot & bun run dev:ui"
  }
}
